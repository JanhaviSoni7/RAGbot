# DeepCytes RAGBot — Environment Configuration
# Copy this to .env and edit as needed.
# Loaded automatically by config.py (optional; all values have defaults).

# Ollama settings
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434
OLLAMA_TEMPERATURE=0.1

# Feature flags
REWRITE_ENABLED=true
NUM_SUBQUERIES=3

# Retrieval knobs
FAISS_TOP_K=20
BM25_TOP_K=20
HYBRID_TOP_K=30
RERANKER_TOP_K=5
